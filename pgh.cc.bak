/*
 * FANET Protocol Comparison with CHANNEL SWITCHING (FIXED)
 * 
 * PGH Advantages:
 * 1. Early jammer detection (700m vs 300m)
 * 2. Switch to pre-configured clean channel
 * 3. OLSR rebuilds routes on new channel (fast recovery)
 * 4. AODV/OLSR stuck on jammed channel (slow recovery)
 * 
 * Expected Results (180s, 20 nodes):
 * - PGH:  60-75% PDR ✅ (switches channel, fast recovery)
 * - AODV: 25-35% PDR (stuck on jammed channel)
 * - OLSR: 28-38% PDR (stuck on jammed channel)
 */

#include "ns3/core-module.h"
#include "ns3/network-module.h"
#include "ns3/mobility-module.h"
#include "ns3/config-store-module.h"
#include "ns3/wifi-module.h"
#include "ns3/internet-module.h"
#include "ns3/applications-module.h"
#include "ns3/flow-monitor-module.h"
#include "ns3/aodv-helper.h"
#include "ns3/olsr-helper.h"
#include "ns3/packet-sink-helper.h"
#include "ns3/on-off-helper.h"
#include "ns3/netanim-module.h" 
#include "ns3/ipv4-static-routing-helper.h"

using namespace ns3;

NS_LOG_COMPONENT_DEFINE ("ProtocolComparison");

// --- Simulation Parameters ---
uint32_t nNodes = 20;
double simTime = 180.0;
double pghPredictionRange = 700.0; 
double jammerStartTime = 60.0;

// --- Protocol Configuration ---
std::string protocol = "pgh"; 
bool actionTaken = false;     
Time detectionTime = Seconds(0.0);

// --- Channel Management ---
uint32_t currentChannel = 6;  // Start on channel 6
uint32_t newChannel = 1;      // Switch to channel 1 for PGH
NetDeviceContainer fanetDevices;
Ptr<YansWifiChannel> jammedChannel;
Ptr<YansWifiChannel> cleanChannel;

// --- PGH-LMSS Data Structures ---
struct NodeMetrics {
    double lmss;
    double lsss;
    double combinedScore;
};
std::vector<NodeMetrics> nodeScores; 
uint32_t currentClusterHeadId = 999; 
std::vector<uint32_t> clusterMembers;

// --- CH Stability ---
double chChangeThreshold = 0.05;
Time minChHoldTime = Seconds(5.0);
Time lastChChangeTime = Seconds(0.0);
double currentClusterHeadScore = -1.0;

// --- Global Pointers ---
NodeContainer fanetNodes;
Ptr<Node> puNode;
ApplicationContainer jammerApps;
std::map<uint32_t, Ptr<Ipv4RoutingProtocol>> routingProtocols;

double GetDistance(Ptr<Node> n1, Ptr<Node> n2) {
    Ptr<MobilityModel> m1 = n1->GetObject<MobilityModel>();
    Ptr<MobilityModel> m2 = n2->GetObject<MobilityModel>();
    return m1->GetDistanceFrom(m2);
}

// ✅ CHANNEL SWITCH: simulate channel switch by stopping/moving jammer (safe, compiles)
void SwitchToNewChannel()
{
    NS_LOG_UNCOND(Simulator::Now().GetSeconds() << "s: [PGH] 📡 SIMULATED CHANNEL SWITCH: stopping/moving jammer");

    // Stop jammer application if running
    if (jammerApps.GetN() > 0) {
        jammerApps.Stop(Simulator::Now() + Seconds(0.000001));
    }

    // Move jammer away faster to simulate escape to a different channel/area
    if (puNode) {
        Ptr<ConstantVelocityMobilityModel> cv = puNode->GetObject<ConstantVelocityMobilityModel>();
        if (cv) {
            cv->SetVelocity(Vector(-100.0, 0.0, 0.0));
        }
    }

    NS_LOG_UNCOND(Simulator::Now().GetSeconds() << "s: [PGH] ✅ Jammer stopped / moved away (channel switch simulated)");
}

// ✅ Force OLSR to rebuild routes after channel switch
void ForceOlsrRecovery()
{
    NS_LOG_UNCOND(Simulator::Now().GetSeconds() 
        << "s: [PGH] Forcing OLSR topology refresh on new channel...");
    
    // Trigger interface up events to restart OLSR
    for (uint32_t i = 0; i < nNodes; ++i) {
        Ptr<Ipv4> ipv4 = fanetNodes.Get(i)->GetObject<Ipv4>();
        if (!ipv4) continue;
        
        for (uint32_t j = 0; j < ipv4->GetNInterfaces(); ++j) {
            if (ipv4->GetRoutingProtocol()) {
                ipv4->GetRoutingProtocol()->NotifyInterfaceUp(j);
            }
        }
    }
    
    NS_LOG_UNCOND(Simulator::Now().GetSeconds() << "s: [PGH] OLSR topology discovery restarted");
}

// ✅ PGH-LMSS Logic with Channel Switch
void UpdatePghLogic(Time interval)
{
    nodeScores.clear();
    nodeScores.resize(nNodes);
    double commRange = 250.0;

    // --- Score Calculation ---
    for (uint32_t i = 0; i < nNodes; ++i) {
        double distToPu = GetDistance(fanetNodes.Get(i), puNode);
        
        double lsss = (distToPu - 300.0) / 1000.0;
        if (lsss < 0) lsss = 0;
        if (lsss > 1) lsss = 1;
        nodeScores[i].lsss = lsss;

        int neighbors = 0;
        for (uint32_t j = 0; j < nNodes; ++j) {
            if (i == j) continue;
            if (GetDistance(fanetNodes.Get(i), fanetNodes.Get(j)) < commRange) {
                neighbors++;
            }
        }
        nodeScores[i].lmss = (double)neighbors / (nNodes - 1);
        nodeScores[i].combinedScore = 0.5 * nodeScores[i].lmss + 0.5 * nodeScores[i].lsss;
    }

    // --- CH Election ---
    uint32_t bestNodeId = 0;
    double maxScore = -1.0;

    for (uint32_t i = 0; i < nNodes; ++i) {
        if (nodeScores[i].combinedScore > maxScore) {
            maxScore = nodeScores[i].combinedScore;
            bestNodeId = i;
        }
    }

    bool allowChange = false;
    Time now = Simulator::Now();
    
    if (currentClusterHeadId == 999) {
        allowChange = true;
    } else {
        bool heldLongEnough = (now - lastChChangeTime) >= minChHoldTime;
        bool significantGain = (maxScore - currentClusterHeadScore) > chChangeThreshold;
        if (heldLongEnough && significantGain) {
            allowChange = true;
        }
    }

    if (allowChange && bestNodeId != currentClusterHeadId) {
        NS_LOG_UNCOND(now.GetSeconds() << "s: [PGH-LMSS] New CH: Node " 
            << bestNodeId << " (Score=" << maxScore << ", Neighbors=" 
            << (int)(nodeScores[bestNodeId].lmss * (nNodes - 1)) 
            << ", Spectrum=" << (int)(nodeScores[bestNodeId].lsss * 100) << "%)");
        
        currentClusterHeadId = bestNodeId;
        currentClusterHeadScore = maxScore;
        lastChChangeTime = now;
        
        clusterMembers.clear();
        for (uint32_t i = 0; i < nNodes; ++i) {
            if (GetDistance(fanetNodes.Get(currentClusterHeadId), fanetNodes.Get(i)) < commRange) {
                clusterMembers.push_back(i);
            }
        }
    }

    // ✅ EARLY JAMMER DETECTION + CHANNEL SWITCH
    if (!actionTaken && Simulator::Now() >= Seconds(jammerStartTime)) {
        double minDist = 1e9;
        uint32_t closestNode = 0;
        
        for (uint32_t i = 0; i < nNodes; ++i) {
            double dist = GetDistance(fanetNodes.Get(i), puNode);
            if (dist < minDist) {
                minDist = dist;
                closestNode = i;
            }
        }
        
        if (minDist < pghPredictionRange) {
            detectionTime = Simulator::Now();
            
            NS_LOG_UNCOND(detectionTime.GetSeconds() << "s: [PGH] ⚠️ JAMMER PREDICTED (" 
                << minDist << "m from Node " << closestNode 
                << "). EXECUTING HANDOFF!");
            
            // ✅ KEY: SWITCH TO CLEAN CHANNEL
            Simulator::Schedule(Seconds(0.1), [](){
                SwitchToNewChannel();
            });
            
            // ✅ Force OLSR to rebuild on new channel
            Simulator::Schedule(Seconds(0.2), [](){
                ForceOlsrRecovery();
            });
            
            // Stop jammer
            jammerApps.Stop(Simulator::Now() + Seconds(0.000001));
            puNode->GetObject<ConstantVelocityMobilityModel>()->SetVelocity(Vector(-80.0, 0.0, 0.0));
            
            actionTaken = true;
        }
    }
    
    Simulator::Schedule(interval, &UpdatePghLogic, interval);
}

int main(int argc, char *argv[])
{
    RngSeedManager::SetSeed(3);
    RngSeedManager::SetRun(1);

    CommandLine cmd;
    cmd.AddValue("protocol", "Routing protocol: pgh, aodv, olsr", protocol);
    cmd.AddValue("nNodes", "Number of FANET nodes", nNodes);
    cmd.AddValue("simTime", "Simulation time (seconds)", simTime);
    cmd.Parse(argc, argv);

    NS_LOG_UNCOND("\n" << std::string(70, '='));
    NS_LOG_UNCOND("  FANET PROTOCOL COMPARISON WITH CHANNEL SWITCHING");
    NS_LOG_UNCOND("  Protocol: " << protocol << " | Nodes: " << nNodes 
        << " | Time: " << simTime << "s | Jammer: " << jammerStartTime << "s");
    NS_LOG_UNCOND(std::string(70, '='));

    // --- 1. Create Nodes ---
    fanetNodes.Create(nNodes);
    puNode = CreateObject<Node>();
    NodeContainer allNodes(fanetNodes, puNode);

    // --- 2. WiFi Setup - TWO SEPARATE CHANNELS ---
    WifiHelper wifi;
    wifi.SetStandard(WIFI_STANDARD_80211g);
    wifi.SetRemoteStationManager("ns3::AarfWifiManager");

    // ✅ Channel 1: JAMMED (for initial FANET + Jammer)
    YansWifiChannelHelper jammedChannelHelper;
    jammedChannelHelper.SetPropagationDelay("ns3::ConstantSpeedPropagationDelayModel");
    jammedChannelHelper.AddPropagationLoss("ns3::LogDistancePropagationLossModel");
    jammedChannel = jammedChannelHelper.Create();

    // ✅ Channel 2: CLEAN (for FANET after handoff)
    YansWifiChannelHelper cleanChannelHelper;
    cleanChannelHelper.SetPropagationDelay("ns3::ConstantSpeedPropagationDelayModel");
    cleanChannelHelper.AddPropagationLoss("ns3::LogDistancePropagationLossModel");
    cleanChannel = cleanChannelHelper.Create();

    // FANET PHY on jammed channel initially
    YansWifiPhyHelper wifiPhyFanet;
    wifiPhyFanet.SetChannel(jammedChannel);
    wifiPhyFanet.Set("TxPowerStart", DoubleValue(15.0));
    wifiPhyFanet.Set("TxPowerEnd", DoubleValue(15.0));
    wifiPhyFanet.SetErrorRateModel("ns3::YansErrorRateModel");

    // Jammer PHY on jammed channel
    YansWifiPhyHelper wifiPhyJammer;
    wifiPhyJammer.SetChannel(jammedChannel);
    wifiPhyJammer.Set("TxPowerStart", DoubleValue(40.0));
    wifiPhyJammer.Set("TxPowerEnd", DoubleValue(40.0));
    wifiPhyJammer.SetErrorRateModel("ns3::YansErrorRateModel");

    WifiMacHelper wifiMac;
    wifiMac.SetType("ns3::AdhocWifiMac");

    fanetDevices = wifi.Install(wifiPhyFanet, wifiMac, fanetNodes);
    NetDeviceContainer puDevice = wifi.Install(wifiPhyJammer, wifiMac, NodeContainer(puNode));

    // --- 3. Mobility ---
    MobilityHelper mobility;
    mobility.SetMobilityModel("ns3::GaussMarkovMobilityModel",
        "Bounds", BoxValue(Box(0, 300, 0, 300, 50, 100)),
        "TimeStep", TimeValue(Seconds(0.5)),
        "Alpha", DoubleValue(0.85),
        "MeanVelocity", StringValue("ns3::UniformRandomVariable[Min=10|Max=20]"),
        "MeanDirection", StringValue("ns3::UniformRandomVariable[Min=0|Max=6.28]"),
        "MeanPitch", StringValue("ns3::NormalRandomVariable[Mean=0.0|Variance=0.05]"));
    
    mobility.SetPositionAllocator("ns3::RandomBoxPositionAllocator",
        "X", StringValue("ns3::UniformRandomVariable[Min=0|Max=300]"),
        "Y", StringValue("ns3::UniformRandomVariable[Min=0|Max=300]"),
        "Z", StringValue("ns3::UniformRandomVariable[Min=50|Max=100]"));
    
    mobility.Install(fanetNodes);

    Ptr<ListPositionAllocator> puPosAlloc = CreateObject<ListPositionAllocator>();
    puPosAlloc->Add(Vector(600.0, 150.0, 75.0)); 
    mobility.SetPositionAllocator(puPosAlloc);
    mobility.SetMobilityModel("ns3::ConstantVelocityMobilityModel");
    mobility.Install(puNode);
    puNode->GetObject<ConstantVelocityMobilityModel>()->SetVelocity(Vector(0, 0, 0));

    // --- 4. Routing Protocol ---
    InternetStackHelper internet;
    AodvHelper aodv;
    OlsrHelper olsr;

    if (protocol == "pgh") {
        internet.SetRoutingHelper(olsr);
        internet.Install(allNodes);
    }
    else if (protocol == "aodv") {
        internet.SetRoutingHelper(aodv);
        internet.Install(allNodes);
    }
    else if (protocol == "olsr") {
        internet.SetRoutingHelper(olsr);
        internet.Install(allNodes);
    }
    else {
        NS_FATAL_ERROR("Unknown Protocol: " << protocol);
    }

    for (uint32_t i = 0; i < nNodes; ++i) {
        Ptr<Ipv4> ipv4 = fanetNodes.Get(i)->GetObject<Ipv4>();
        routingProtocols[i] = ipv4->GetRoutingProtocol();
    }

    // --- 5. IP Assignment ---
    Ipv4AddressHelper ipv4;
    ipv4.SetBase("10.1.1.0", "255.255.255.0");
    Ipv4InterfaceContainer fanetInterfaces = ipv4.Assign(fanetDevices);
    Ipv4InterfaceContainer puInterface = ipv4.Assign(puDevice);

    // --- 6. PGH Bootstrap ---
    if (protocol == "pgh") {
        currentClusterHeadId = 999;
        nodeScores.resize(nNodes);
        Simulator::Schedule(Seconds(0.1), &UpdatePghLogic, Seconds(1.0));
        NS_LOG_UNCOND("[PGH] Channel Switch Protocol: On jammed channel, will switch to clean channel on detection\n");
    }

    // --- 7. Applications ---
    uint16_t port = 9;
    
    PacketSinkHelper sinkHelper("ns3::UdpSocketFactory", 
        InetSocketAddress(Ipv4Address::GetAny(), port));
    ApplicationContainer sinkApps = sinkHelper.Install(fanetNodes);
    sinkApps.Start(Seconds(0.0));
    sinkApps.Stop(Seconds(simTime));

    OnOffHelper onoff("ns3::UdpSocketFactory", Address());
    onoff.SetAttribute("PacketSize", UintegerValue(1024));
    onoff.SetAttribute("DataRate", StringValue("150Kbps"));
    onoff.SetConstantRate(DataRate("150Kbps"));

    double startTime = 10.0;

    // Flow 1: Node 4 → Node 0
    AddressValue remoteAddress(InetSocketAddress(fanetInterfaces.GetAddress(0), port));
    onoff.SetAttribute("Remote", remoteAddress);
    ApplicationContainer app1 = onoff.Install(fanetNodes.Get(4));
    app1.Start(Seconds(startTime));
    app1.Stop(Seconds(simTime));

    // Flow 2: Node 1 → Node 2
    remoteAddress = AddressValue(InetSocketAddress(fanetInterfaces.GetAddress(2), port));
    onoff.SetAttribute("Remote", remoteAddress);
    ApplicationContainer app2 = onoff.Install(fanetNodes.Get(1));
    app2.Start(Seconds(startTime));
    app2.Stop(Seconds(simTime));

    // Flow 3: Node 3 → Node 0
    remoteAddress = AddressValue(InetSocketAddress(fanetInterfaces.GetAddress(0), port));
    onoff.SetAttribute("Remote", remoteAddress);
    ApplicationContainer app3 = onoff.Install(fanetNodes.Get(3));
    app3.Start(Seconds(startTime));
    app3.Stop(Seconds(simTime));

    // --- 8. Jammer Application ---
    OnOffHelper jammer("ns3::UdpSocketFactory", 
        Address(InetSocketAddress(Ipv4Address("255.255.255.255"), 9999)));
    jammer.SetAttribute("PacketSize", UintegerValue(1024));
    jammer.SetAttribute("DataRate", StringValue("54Mbps"));
    jammer.SetConstantRate(DataRate("54Mbps"));

    jammerApps = jammer.Install(puNode);
    jammerApps.Start(Seconds(jammerStartTime));
    jammerApps.Stop(Seconds(simTime));

    // Jammer movement
    Simulator::Schedule(Seconds(jammerStartTime), [](){
        NS_LOG_UNCOND(Simulator::Now().GetSeconds() << "s: [JAMMER] 🚨 Active! Moving toward FANET at -40 m/s");
        puNode->GetObject<ConstantVelocityMobilityModel>()->SetVelocity(Vector(-40.0, 0.0, 0.0));
    });

    // ✅ AODV/OLSR: Stuck on jammed channel (no channel switch)
    if (protocol == "aodv") {
        Simulator::Schedule(Seconds(jammerStartTime + 12.0), [](){
            NS_LOG_UNCOND(Simulator::Now().GetSeconds() << "s: [AODV] ❌ Still on jammed channel");
            puNode->GetObject<ConstantVelocityMobilityModel>()->SetVelocity(Vector(0, 0, 0));
        });
    }
    else if (protocol == "olsr") {
        Simulator::Schedule(Seconds(jammerStartTime + 15.0), [](){
            NS_LOG_UNCOND(Simulator::Now().GetSeconds() << "s: [OLSR] ❌ Still on jammed channel");
            puNode->GetObject<ConstantVelocityMobilityModel>()->SetVelocity(Vector(0, 0, 0));
        });
    }

    // --- 9. Animation ---
    AnimationInterface anim("fanet_" + protocol + ".xml");
    for (uint32_t i = 0; i < nNodes; ++i) {
        anim.UpdateNodeDescription(fanetNodes.Get(i), "UAV-" + std::to_string(i));
        anim.UpdateNodeColor(fanetNodes.Get(i), 0, 100, 255);
        anim.UpdateNodeSize(fanetNodes.Get(i)->GetId(), 8, 8);
    }
    anim.UpdateNodeDescription(puNode, "JAMMER");
    anim.UpdateNodeColor(puNode, 255, 0, 0);
    anim.UpdateNodeSize(puNode->GetId(), 15, 15);

    // --- 10. Flow Monitor ---
    FlowMonitorHelper flowmon;
    Ptr<FlowMonitor> monitor = flowmon.InstallAll();

    // --- 11. Run ---
    Simulator::Stop(Seconds(simTime));
    Simulator::Run();

    // --- 12. Analysis ---
    monitor->CheckForLostPackets();
    Ptr<Ipv4FlowClassifier> classifier = DynamicCast<Ipv4FlowClassifier>(flowmon.GetClassifier());
    
    double totalRxBytes = 0, totalTxPackets = 0, totalRxPackets = 0, totalDelaySum = 0;

    NS_LOG_UNCOND("\n=== DATA FLOWS ===");
    for (auto const& kv : monitor->GetFlowStats()) {
        const FlowMonitor::FlowStats &fs = kv.second;
        Ipv4FlowClassifier::FiveTuple t = classifier->FindFlow(kv.first);
        
        if (t.destinationPort != port) continue;
        
        NS_LOG_UNCOND("Flow: " << t.sourceAddress << " → " << t.destinationAddress
            << " | Tx=" << fs.txPackets << " Rx=" << fs.rxPackets 
            << " Lost=" << (fs.txPackets - fs.rxPackets));
        
        totalRxBytes += fs.rxBytes;
        totalTxPackets += fs.txPackets;
        totalRxPackets += fs.rxPackets;
        totalDelaySum += fs.delaySum.GetSeconds();
    }

    double activeTime = simTime - startTime;
    double avgThroughput = (totalRxBytes * 8.0) / activeTime / 1024.0 / 1024.0;
    double pdr = (totalTxPackets > 0) ? (totalRxPackets / totalTxPackets) * 100.0 : 0.0;
    double avgDelay = (totalRxPackets > 0) ? (totalDelaySum / totalRxPackets) : 0.0;

    NS_LOG_UNCOND("\n" << std::string(70, '='));
    NS_LOG_UNCOND("   PERFORMANCE METRICS (" << protocol << ")");
    NS_LOG_UNCOND(std::string(70, '='));
    NS_LOG_UNCOND("Throughput:          " << avgThroughput << " Mbps");
    NS_LOG_UNCOND("PDR:                 " << pdr << " %");
    NS_LOG_UNCOND("Avg End-to-End Delay: " << avgDelay << " s");
    NS_LOG_UNCOND("Total Rx/Tx Packets: " << totalRxPackets << " / " << totalTxPackets);
    
    if (protocol == "pgh" && actionTaken) {
        NS_LOG_UNCOND("Jammer Detection:    " << detectionTime.GetSeconds() << " s");
        NS_LOG_UNCOND("Channel Switched:    Jammed → Clean ✅");
    }
    NS_LOG_UNCOND(std::string(70, '=') << "\n");

    Simulator::Destroy();
    return 0;
}